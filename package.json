{
  "name": "folio",
  "version": "1.0.0",
  "description": "Folio — University Form Generator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.folio.app",
    "productName": "Folio",
    "directories": { "output": "dist" },
    "win": {
      "target": [{"target":"portable","arch":["x64"]}],
      "icon": "assets/icon.ico"
    },
    "files": ["**/*", "!folio/**", "!.claude/**", "!dist/**", "!scripts/**", "!node_modules/electron-builder/**"],
    "extraResources": [{"from":"templates/","to":"templates/"},{"from":"assets/","to":"assets/"}]
  }
}
